<%= form_with model: [:admin, download_client], class: "contents" do |form| %>
  <% if download_client.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 font-medium rounded-lg mt-3">
      <h2><%= pluralize(download_client.errors.count, "error") %> prohibited this client from being saved:</h2>
      <ul class="list-disc list-inside mt-2">
        <% download_client.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-gray-300 font-medium" %>
    <%= form.text_field :name, required: true, placeholder: "e.g., Home qBittorrent", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :client_type, "Type", class: "block text-gray-300 font-medium" %>
    <%= form.select :client_type, DownloadClient.client_types.keys.map { |t| [t.titleize, t] }, {}, class: "block rounded-lg border border-gray-700 bg-gray-800 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full", data: { action: "change->download-client-form#toggleFields" }, id: "client_type_select" %>
  </div>

  <div class="my-5">
    <%= form.label :url, "URL", class: "block text-gray-300 font-medium" %>
    <%= form.text_field :url, required: true, placeholder: "http://192.168.1.100:8080", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
    <p class="mt-1 text-sm text-gray-500">Include the protocol (http/https) and port</p>
  </div>

  <div id="authentication_fields" class="<%= 'hidden' unless download_client.requires_authentication? || download_client.new_record? %>">
    <div class="my-5">
      <%= form.label :username, class: "block text-gray-300 font-medium" %>
      <%= form.text_field :username, placeholder: "admin", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block text-gray-300 font-medium" %>
      <div class="flex items-center gap-3 mt-2">
        <%= form.password_field :password, placeholder: download_client.persisted? ? "Leave blank to keep current" : "Enter password", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 flex-grow" %>
        <% if download_client.persisted? && download_client.password.present? %>
          <span class="text-green-400 text-sm flex items-center gap-1 whitespace-nowrap">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Saved
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <div id="sabnzbd_fields" class="<%= 'hidden' unless download_client.sabnzbd? %>">
    <div class="my-5">
      <%= form.label :api_key, "API Key", class: "block text-gray-300 font-medium" %>
      <div class="flex items-center gap-3 mt-2">
        <%= form.password_field :api_key, placeholder: download_client.persisted? && download_client.api_key.present? ? "Leave blank to keep current" : "Enter API key", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 flex-grow" %>
        <% if download_client.persisted? && download_client.api_key.present? %>
          <span class="text-green-400 text-sm flex items-center gap-1 whitespace-nowrap">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Saved
          </span>
        <% end %>
      </div>
      <p class="mt-1 text-sm text-gray-500">Found in SABnzbd under Config > General > API Key</p>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :category, class: "block text-gray-300 font-medium" %>
    <%= form.text_field :category, placeholder: "shelfarr", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
    <p class="mt-1 text-sm text-gray-500">Optional. Downloads will be added to this category.</p>
  </div>

  <div class="my-5">
    <%= form.label :download_path, "Download Path", class: "block text-gray-300 font-medium" %>
    <%= form.text_field :download_path, placeholder: "/downloads", class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
    <p class="mt-1 text-sm text-gray-500">Container path where completed downloads appear (e.g., /downloads). Leave blank to use global settings.</p>
  </div>

  <div id="qbittorrent_fields" class="<%= 'hidden' unless download_client.qbittorrent? || download_client.new_record? %>">
    <div class="grid gap-5 md:grid-cols-2">
      <div>
        <%= form.label :torrent_verification_max_attempts, "Torrent Verification Attempts", class: "block text-gray-300 font-medium" %>
        <%= form.number_field :torrent_verification_max_attempts, min: 1, class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
        <p class="mt-1 text-sm text-gray-500">How many times Shelfarr should poll qBittorrent to confirm a newly added torrent exists.</p>
      </div>

      <div>
        <%= form.label :torrent_verification_wait_time, "Verification Wait Time (Seconds)", class: "block text-gray-300 font-medium" %>
        <%= form.number_field :torrent_verification_wait_time, min: 0, class: "block rounded-lg border border-gray-700 bg-gray-800 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 px-4 py-3 mt-2 w-full" %>
        <p class="mt-1 text-sm text-gray-500">Delay between verification attempts. Increase this if qBittorrent runs behind a VPN or slow network path.</p>
      </div>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :enabled, class: "flex items-center gap-2 cursor-pointer" %>
    <div class="flex items-center">
      <%= form.check_box :enabled, class: "rounded border-gray-600 bg-gray-800 text-blue-600 focus:ring-blue-500 focus:ring-offset-gray-900" %>
      <span class="ml-2 text-gray-300">Enabled</span>
    </div>
  </div>

  <div class="flex items-center gap-4 mt-8">
    <%= form.submit class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white cursor-pointer" %>
    <%= link_to "Cancel", admin_download_clients_path, class: "text-gray-400 hover:text-gray-300" %>
  </div>
<% end %>

<script>
  // Use turbo:load for Turbo navigations and DOMContentLoaded for initial page load
  function initDownloadClientForm() {
    const clientTypeSelect = document.getElementById('client_type_select');
    const authenticationFields = document.getElementById('authentication_fields');
    const sabnzbdFields = document.getElementById('sabnzbd_fields');
    const qbittorrentFields = document.getElementById('qbittorrent_fields');

    if (!clientTypeSelect || !authenticationFields || !sabnzbdFields || !qbittorrentFields) return;

    function toggleFields() {
      const type = clientTypeSelect.value;
      authenticationFields.classList.toggle(
        'hidden',
        !['qbittorrent', 'decypharr', 'nzbget', 'deluge', 'transmission'].includes(type)
      );
      sabnzbdFields.classList.toggle('hidden', type !== 'sabnzbd');
      qbittorrentFields.classList.toggle('hidden', type !== 'qbittorrent');
    }

    // Run on load to set initial state
    toggleFields();

    // Listen for changes
    clientTypeSelect.addEventListener('change', toggleFields);
  }

  document.addEventListener('DOMContentLoaded', initDownloadClientForm);
  document.addEventListener('turbo:load', initDownloadClientForm);
  document.addEventListener('turbo:render', initDownloadClientForm);
</script>
